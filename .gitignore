###################################################################
# Visual Studio / .NET 관련 파일 및 폴더
###################################################################

# 빌드 폴더 (바이너리 출력)
bin/
obj/

# Visual Studio 사용자별 설정 파일
*.user
*.suo
*.vs/

# Visual Studio Code 설정(선택)
.vscode/

# Rider IDE 설정(선택)
.idea/

# NuGet 패키지 폴더
packages/

# 로그 및 디버깅 관련 결과
*.log
*.tmp

# 빌드 후 생성될 실행 파일 등 (선택)
*.exe
*.dll
*.pdb

###################################################################
# 운영체제(Windows/macOS) 메타데이터 
###################################################################
Thumbs.db
.DS_Store
